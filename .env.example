# URL pública do site (usada para metadados / Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chave da OpenAI para o assistente de entrega
OPENAI_API_KEY=sk-...

# Modelo da OpenAI (opcional)
OPENAI_MODEL=gpt-4.1-mini

# Segredo para assinatura de tokens de autenticação (>=32 caracteres).
# O script scripts/bootstrap.ts gera um automaticamente em .env.local se ausente.
AUTH_SECRET=

# Origens permitidas no modo de desenvolvimento (separadas por vírgula)
ALLOWED_DEV_ORIGINS=localhost:3000

# Banco de dados (Turso/libSQL). Sem estas variáveis o app usa um arquivo
# SQLite local (file:cpv.db) — adequado apenas para desenvolvimento.
# Em produção (Vercel) ambas são OBRIGATÓRIAS: o filesystem serverless é
# efêmero e um banco em arquivo não persiste.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
